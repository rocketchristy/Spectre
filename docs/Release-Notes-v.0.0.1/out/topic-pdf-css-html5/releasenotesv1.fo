retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="xsl-footnote-separator" role="artifact" text-align="left" display-align="auto" font-size="10pt" font-family="Roboto , sans-serif" border-top-style="solid" border-top-color="black" border-top-width="thin" padding-top="8pt"><fo:block/></fo:static-content><fo:flow flow-name="xsl-region-body"><fo:block font-family="serif" font-size="12px" min-width="100%" xml:lang="en"><fo:block-container font-family="Roboto, sans-serif" font-size="10pt" margin-left="0" margin-right="0" min-width="100%"><fo:block end-indent="0" start-indent="0"><fo:block-container color="rgb(0 , 0 , 0)" line-height="1.7em" space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block><fo:block-container space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block xml:lang="en"><fo:block-container space-before="1em" id="unique_1" chfox:nd-id="release_notes_whats_new_whats_fixed"><fo:block end-indent="0" start-indent="0" role="Sect">
                            <fo:block-container font-size="2em" line-height="1.1em" space-after="0.5em" margin-left="0" margin-right="0" space-before="0" page-break-after="avoid" id="ariaid-title1"><fo:block end-indent="0" start-indent="0" role="H1"><fo:marker marker-class-name="chaptertitle-no-prefix"><fo:inline/> 1 - <!--content(text)--><fo:inline>NXTCG v 0.0.1 Release Notes: What’s New and What’s Fixed</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle"><fo:inline/> | 1 - <!--content(text)--><fo:inline>NXTCG v 0.0.1 Release Notes: What’s New and What’s Fixed</fo:inline></fo:marker><fo:inline>Chapter 1. </fo:inline><fo:inline>NXTCG v 0.0.1 Release Notes: What’s New and
                                    What’s Fixed</fo:inline></fo:block></fo:block-container>
                            
                            <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                <fo:block-container space-after="1em" space-before="1em"><fo:block end-indent="0" start-indent="0" role="Sect">
                                    <fo:block-container id="d39e435" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H2">Overview</fo:block></fo:block-container>
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"> This release of
                                        the NXTCG platform introduces core marketplace
                                        functionality, allowing users to buy, sell, and manage
                                        NextGen trading cards through a fully integrated frontend
                                        and backend experience. The release focuses on establishing
                                        the end-to-end purchase flow, product configuration, user
                                        profile management, and platform stability. </fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                                <fo:block-container space-after="1em" space-before="1em"><fo:block end-indent="0" start-indent="0" role="Sect">
                                    <fo:block-container id="d39e447" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H2">What’s
                                        New</fo:block></fo:block-container>
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"> NXTCG now
                                        supports a complete trading card marketplace experience.
                                        Users can browse available cards, configure product
                                        attributes, add customized items to their cart, and securely
                                        complete checkout. Sellers can list cards for sale and
                                        manage their inventory directly from their user profile. The
                                        platform also introduces a modern storefront interface,
                                        navigation components, and landing pages to support
                                        discovery and usability. </fo:block></fo:block-container>
                                    <fo:block>
                                        <fo:table-and-caption border-collapse="collapse" space-before="1em" space-after="1em"><fo:table-caption start-indent="0" end-indent="0" keep-with-next="always"><fo:block-container font-weight="bold" margin-top="0.5em" page-break-after="avoid" text-align="left"><fo:block end-indent="0" start-indent="0"><fo:inline>Table<fo:inline> 1</fo:inline><fo:inline>. </fo:inline></fo:inline><fo:inline><fo:inline>New
                                                Features</fo:inline></fo:inline></fo:block></fo:block-container></fo:table-caption><fo:table-caption-for-next-page start-indent="0" end-indent="0" keep-with-next="always"><fo:block-container font-weight="bold" margin-top="0.5em" page-break-after="avoid" text-align="left"><fo:block end-indent="0" start-indent="0"><fo:inline>Table<fo:inline> 1</fo:inline><fo:inline>. </fo:inline></fo:inline><fo:inline><fo:inline>New
                                                Features</fo:inline></fo:inline><fo:inline> (continued)</fo:inline></fo:block></fo:block-container></fo:table-caption-for-next-page><fo:table relative-align="baseline" chfox:html-table-width-policy="yes" table-layout="auto" hyphenate="true" id="d117e106" space-before="0" space-after="0"><fo:table-column column-width="20%"/><fo:table-column column-width="60%"/><fo:table-column column-width="20%"/><fo:table-header font-weight="bold" text-align="center" display-align="center">
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="unique_1__d117e106__entry__1"><fo:block>Jira ID</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="unique_1__d117e106__entry__2"><fo:block>Description</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="unique_1__d117e106__entry__3"><fo:block>Area</fo:block></fo:table-cell>
                                                </fo:table-row>
                                            </fo:table-header><fo:table-body display-align="center">
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-243</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Users can configure products, add them to an
                                                  order, and enter payment and address details
                                                  during checkout.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Checkout</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-244</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Users can select product quantities before adding
                                                  items to their cart.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Cart</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-246</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Support for configurable product attributes for
                                                  trading cards.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Products</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-247</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Users can add multiple customized products to
                                                  their cart.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Cart</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-248</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Users can enter a delivery address during
                                                  checkout.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Checkout</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-249</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Users can enter a billing address as part of the
                                                  checkout process.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Checkout</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-250</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Users can submit and complete orders through the
                                                  checkout workflow.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Checkout</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-292</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Order history now displays purchased trading
                                                  cards correctly.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Orders</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-197</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Introduced a landing page to support storefront
                                                  access and discovery.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>UI</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-137</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Implemented storefront and product views for
                                                  browsing available cards.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Storefront</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-138</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Added navigation bar and footer views to improve
                                                  site navigation.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>UI</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-200</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>User profiles now display the trading cards a
                                                  user has listed for sale.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>User Profile</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-291</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Sellers can delete items they have listed for
                                                  sale.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Marketplace</fo:block></fo:table-cell>
                                                </fo:table-row>
                                            </fo:table-body></fo:table></fo:table-and-caption>
                                    </fo:block>
                                </fo:block></fo:block-container>
                                <fo:block-container space-after="1em" space-before="1em"><fo:block end-indent="0" start-indent="0" role="Sect">
                                    <fo:block-container id="d39e664" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H2">What’s
                                        Fixed</fo:block></fo:block-container>
                                    <fo:block>
                                        <fo:table-and-caption border-collapse="collapse" space-before="1em" space-after="1em"><fo:table-caption start-indent="0" end-indent="0" keep-with-next="always"><fo:block-container font-weight="bold" margin-top="0.5em" page-break-after="avoid" text-align="left"><fo:block end-indent="0" start-indent="0"><fo:inline>Table<fo:inline> 2</fo:inline><fo:inline>. </fo:inline></fo:inline><fo:inline><fo:inline>Bug
                                                Fixes</fo:inline></fo:inline></fo:block></fo:block-container></fo:table-caption><fo:table-caption-for-next-page start-indent="0" end-indent="0" keep-with-next="always"><fo:block-container font-weight="bold" margin-top="0.5em" page-break-after="avoid" text-align="left"><fo:block end-indent="0" start-indent="0"><fo:inline>Table<fo:inline> 2</fo:inline><fo:inline>. </fo:inline></fo:inline><fo:inline><fo:inline>Bug
                                                Fixes</fo:inline></fo:inline><fo:inline> (continued)</fo:inline></fo:block></fo:block-container></fo:table-caption-for-next-page><fo:table relative-align="baseline" chfox:html-table-width-policy="yes" table-layout="auto" hyphenate="true" id="d117e303" space-before="0" space-after="0"><fo:table-column column-width="20%"/><fo:table-column column-width="60%"/><fo:table-column column-width="20%"/><fo:table-header font-weight="bold" text-align="center" display-align="center">
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="unique_1__d117e303__entry__1"><fo:block>Jira ID</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="unique_1__d117e303__entry__2"><fo:block>Description</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="unique_1__d117e303__entry__3"><fo:block>Area</fo:block></fo:table-cell>
                                                </fo:table-row>
                                            </fo:table-header><fo:table-body display-align="center">
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-296</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Fixed an issue where the storefront displayed
                                                  incorrect available listings.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Storefront</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-292</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Resolved an issue where order history did not
                                                  return purchased cards.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Orders</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-229</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Prevented users from updating their profile
                                                  information and password at the same time.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>User Profile</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-232</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>User authentication tokens are now invalidated
                                                  after password changes, requiring re-login.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Security</fo:block></fo:table-cell>
                                                </fo:table-row>
                                                <fo:table-row display-align="center">
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-202</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Stabilized the automated testing environment to
                                                  prevent pipeline failures.</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Testing</fo:block></fo:table-cell>
                                                </fo:table-row>
                                            </fo:table-body></fo:table></fo:table-and-caption>
