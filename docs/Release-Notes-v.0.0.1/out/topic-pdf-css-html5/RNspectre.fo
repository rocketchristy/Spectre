    <fo:block-container font-family="Roboto, sans-serif" font-size="10pt" margin-left="0" margin-right="0" min-width="100%"><fo:block end-indent="0" start-indent="0">
        <fo:block-container color="rgb(0 , 0 , 0)" line-height="1.7em" space-after="80px"><fo:block end-indent="0" start-indent="0">
            <fo:block>
                <fo:block-container space-after="80px"><fo:block end-indent="0" start-indent="0">
                    <fo:block role="Sect" id="release_notes_whats_new_whats_fixed" xml:lang="en">
                        <fo:block-container font-size="2em" line-height="1.1em" space-after="0.5em" margin-left="0" margin-right="0" space-before="0" page-break-after="avoid" id="ariaid-title1"><fo:block end-indent="0" start-indent="0" role="H1"><fo:inline>NXTCG v 0.0.1 Release Notes: What’s New and
                                What’s Fixed</fo:inline></fo:block></fo:block-container>
                        <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                            <fo:block-container space-after="1em" space-before="1em"><fo:block end-indent="0" start-indent="0" role="Sect">
                                <fo:block-container id="d39e258" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H2">Overview</fo:block></fo:block-container>
                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">
                                    This release of the NXTCG platform introduces core marketplace
                                    functionality, allowing users to buy, sell, and manage NextGen
                                    trading cards through a fully integrated frontend and backend
                                    experience. The release focuses on establishing the end-to-end
                                    purchase flow, product configuration, user profile management,
                                    and platform stability. </fo:block></fo:block-container>
                            </fo:block></fo:block-container>
                            <fo:block-container space-after="1em" space-before="1em"><fo:block end-indent="0" start-indent="0" role="Sect">
                                <fo:block-container id="d39e270" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H2">What’s
                                    New</fo:block></fo:block-container>
                                <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">
                                    NXTCG now supports a complete trading card marketplace
                                    experience. Users can browse available cards, configure product
                                    attributes, add customized items to their cart, and securely
                                    complete checkout. Sellers can list cards for sale and manage
                                    their inventory directly from their user profile. The platform
                                    also introduces a modern storefront interface, navigation
                                    components, and landing pages to support discovery and
                                    usability. </fo:block></fo:block-container>
                                <fo:block>
                                    <fo:table-and-caption border-collapse="collapse" space-before="1em" space-after="1em"><fo:table-caption start-indent="0" end-indent="0" keep-with-next="always"><fo:block-container font-weight="bold" margin-top="0.5em" page-break-after="avoid" text-align="left"><fo:block end-indent="0" start-indent="0"><fo:inline>Table<fo:inline> 1</fo:inline><fo:inline>. </fo:inline></fo:inline><fo:inline><fo:inline>New
                                            Features</fo:inline></fo:inline></fo:block></fo:block-container></fo:table-caption><fo:table-caption-for-next-page start-indent="0" end-indent="0" keep-with-next="always"><fo:block-container font-weight="bold" margin-top="0.5em" page-break-after="avoid" text-align="left"><fo:block end-indent="0" start-indent="0"><fo:inline>Table<fo:inline> 1</fo:inline><fo:inline>. </fo:inline></fo:inline><fo:inline><fo:inline>New
                                            Features</fo:inline></fo:inline><fo:inline> (continued)</fo:inline></fo:block></fo:block-container></fo:table-caption-for-next-page><fo:table relative-align="baseline" chfox:html-table-width-policy="yes" table-layout="auto" border-bottom-color="black" border-bottom-style="solid" border-bottom-width="1px" border-left-color="black" border-left-style="solid" border-left-width="1px" margin-left="0" border-right-color="black" border-right-style="solid" border-right-width="1px" margin-right="0" border-top-color="black" border-top-style="solid" border-top-width="1px" hyphenate="true" id="d64e32" space-before="0" space-after="0"><fo:table-column column-width="20%"/><fo:table-column column-width="60%"/><fo:table-column column-width="20%"/><fo:table-header font-weight="bold" text-align="center" display-align="center">
                                            <fo:table-row display-align="center">
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="release_notes_whats_new_whats_fixed__d64e32__entry__1"><fo:block>Jira ID</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="release_notes_whats_new_whats_fixed__d64e32__entry__2"><fo:block>Description</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="release_notes_whats_new_whats_fixed__d64e32__entry__3"><fo:block>Area</fo:block></fo:table-cell>
                                            </fo:table-row>
                                        </fo:table-header><fo:table-body display-align="center">
                                            <fo:table-row display-align="center">
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-243</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Users can configure products, add them to an
                                                  order, and enter payment and address details
                                                  during checkout.</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Checkout</fo:block></fo:table-cell>
                                            </fo:table-row>
                                            <fo:table-row display-align="center">
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-244</fo:block></fo:table-cell>
