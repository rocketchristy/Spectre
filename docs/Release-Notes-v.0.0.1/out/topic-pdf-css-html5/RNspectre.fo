                                            <fo:table-row display-align="center">
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="release_notes_whats_new_whats_fixed__d64e229__entry__1"><fo:block>Jira ID</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="release_notes_whats_new_whats_fixed__d64e229__entry__2"><fo:block>Description</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" id="release_notes_whats_new_whats_fixed__d64e229__entry__3"><fo:block>Area</fo:block></fo:table-cell>
                                            </fo:table-row>
                                        </fo:table-header><fo:table-body display-align="center">
                                            <fo:table-row display-align="center">
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-296</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Fixed an issue where the storefront displayed
                                                  incorrect available listings.</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Storefront</fo:block></fo:table-cell>
                                            </fo:table-row>
                                            <fo:table-row display-align="center">
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-292</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Resolved an issue where order history did not
                                                  return purchased cards.</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Orders</fo:block></fo:table-cell>
                                            </fo:table-row>
                                            <fo:table-row display-align="center">
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-229</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Prevented users from updating their profile
                                                  information and password at the same time.</fo:block></fo:table-cell>
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>User Profile</fo:block></fo:table-cell>
                                            </fo:table-row>
                                            <fo:table-row display-align="center">
                                                <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>NAR-232</fo:block></fo:table-cell>
