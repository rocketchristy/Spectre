                                                  <fo:block-container space-after="1em" margin-left="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="700"><fo:inline color="rgb(81 , 133 , 203)"><fo:basic-link show-destination="new" indicate-destination="true" internal-destination="unique_4" fox:alt-text="Adding tables to the ECOMAPP Database">Adding tables to the ECOMAPP
                                                  Database</fo:basic-link></fo:inline></fo:inline></fo:block></fo:block-container>
                                                  <fo:block-container space-after="1em" margin-left="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="700"><fo:inline color="rgb(81 , 133 , 203)"><fo:basic-link show-destination="new" indicate-destination="true" internal-destination="unique_5" fox:alt-text="Troubleshooting the NXTCG ECOMAPP database">Troubleshooting the NXTCG
                                                  ECOMAPP database</fo:basic-link></fo:inline></fo:inline></fo:block></fo:block-container>
                                                </fo:block></fo:block-container>
                                            </fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                    </fo:block>
                                </fo:block>
                            </fo:block>
                            <fo:block role="Sect" id="unique_2" xml:lang="en" chfox:nd-id="dbdocstopic1">
                                <fo:block-container font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid" id="ariaid-title2"><fo:block end-indent="0" start-indent="0" role="H2"><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e245"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e249"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e253"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e257"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e261"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e266"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e270"/><fo:inline>ECOMAPP Database
                                    Architecture</fo:inline></fo:block></fo:block-container>
                                
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0"><fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="0.5em"><fo:block end-indent="0" start-indent="0">The database design and architecture
                                        includes SKU composition, multiplier-based pricing, and
                                        normalized entities with referential integrity. NXTCG's
                                        database is hosted on Db2 13 for z/OS.</fo:block></fo:block-container>
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"> ECOMAPP is a
                                        normalized, SKU-driven data model with centralized pricing
                                        logic and strong referential integrity. The catalog supports
                                        4,824 sellable SKUs derived from 104 base product types and
                                        63 style modifiers, designed to be scalable and consistent
                                        with updates.</fo:block></fo:block-container>
                                    <fo:inline chfox:inch="true" max-width="100%" id="unique_2_Connect_42_image_ugv_53r_q3c" chfox:nd-id="image_ugv_53r_q3c"><fo:inline><fo:external-graphic src="file:/C:/Users/jheckel/Downloads/Image%20(3).jpg" max-width="100%" scaling="uniform" width="912in div 96" content-width="scale-to-fit" height="1178in div 96" content-height="scale-to-fit"/></fo:inline></fo:inline>
                                    <fo:block-container space-after="1em" space-before="1em" id="unique_2_Connect_42_section_tsz_szw_q3c" chfox:nd-id="section_tsz_szw_q3c"><fo:block end-indent="0" start-indent="0" role="Sect">
                                        <fo:block-container id="d39e805" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3">ECOMAPP
                                            database components</fo:block></fo:block-container>
                                        <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">The ECOMDB01
                                            database is organized into 15 tablespaces, with each
                                            table placed in its own space to support flexibility and
                                            management. It includes the USERS, TOKENS, SERIES,
                                            STYLES, STYLE_MODIFIERS, PRODUCT_TYPES,
                                            PRODUCT_VARIANTS, VARIANT_IMAGES, INVENTORY, CARTS,
                                            CART_ITEMS, ADDRESSES, ORDERS, ORDER_ADDRESSES, and
                                            ORDER_ITEMS tables, covering the core data structures of
                                            the system. Indexing is handled through primary key
                                            indexes along with business key indexes to maintain
                                            efficient and reliable query performance.</fo:block></fo:block-container>
                                    </fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" space-before="1em" id="unique_2_Connect_42_section_mgk_4rd_q3c" chfox:nd-id="section_mgk_4rd_q3c"><fo:block end-indent="0" start-indent="0" role="Sect">
                                        <fo:block-container id="d39e817" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3">Normalization</fo:block></fo:block-container>
                                        <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">ECOMAPP NXTCG
                                            demonstrates a high level of normalization, with the
                                            schema aligning with Third Normal Form (3NF). All
                                            relations satisfy the requirements of First and Second
                                            Normal Forms, and the use of composite‑key tables
                                            ensures that each non‑key attribute is fully dependent
                                            on the entire primary key.</fo:block></fo:block-container>
                                    </fo:block></fo:block-container>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_3" xml:lang="en" chfox:nd-id="installingdb2">
                                <fo:block-container font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid" id="ariaid-title3"><fo:block end-indent="0" start-indent="0" role="H2"><fo:inline>Installing the ECOMAPP
                                    database</fo:inline></fo:block></fo:block-container>
                                
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="0.5em"><fo:block end-indent="0" start-indent="0">ECOMAPP database
                                        is hosted on Db2 for z/OS platform. You can install the
                                        ECOMAPP database within TSO/ISPF.</fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" space-before="1em"><fo:block end-indent="0" start-indent="0" role="Sect">
                                        <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">Before
                                            installing ECOMAPP, you must have these requirements: </fo:block></fo:block-container>
                                        <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em" id="unique_3_Connect_42_ul_ncw_xcd_q3c" chfox:nd-id="ul_ncw_xcd_q3c">
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end"><fo:inline font-family="Times New Roman,Liberation Serif,DejaVu Serif,Symbol,Segoe UI Symbol,FreeSerif,ZapfDingbats">• </fo:inline></fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Access: You must have access to TSO/ISPF. </fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end"><fo:inline font-family="Times New Roman,Liberation Serif,DejaVu Serif,Symbol,Segoe UI Symbol,FreeSerif,ZapfDingbats">• </fo:inline></fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Db2:
                                                Version 13, subsystem ID <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your SSID&gt;</fo:inline>, Db2 software HLQ <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your DB2HLQ&gt;</fo:inline>, and a Db2 Connect
                                                license.</fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end"><fo:inline font-family="Times New Roman,Liberation Serif,DejaVu Serif,Symbol,Segoe UI Symbol,FreeSerif,ZapfDingbats">• </fo:inline></fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>User
                                                Privileges: SYSADM/SYSCTRL or CREATEDB.</fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end"><fo:inline font-family="Times New Roman,Liberation Serif,DejaVu Serif,Symbol,Segoe UI Symbol,FreeSerif,ZapfDingbats">• </fo:inline></fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Storage: 100 tracks for DDL library, 50 tracks for
                                                JCL library, 500 MB DASD for tablespaces and
                                                indexes.</fo:block></fo:list-item-body></fo:list-item>
                                        </fo:list-block>
                                    </fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" space-before="1em"><fo:block end-indent="0" start-indent="0" role="Sect">Below are
                                        steps instructing you on how to install ECOMAPP database
                                        within TSO/ISPF.</fo:block></fo:block-container>
                                    <fo:block role="Sect">
                                        <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">1. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                <fo:inline>Before uploading any files,
                                                  you must customize the following placeholders
                                                  throughout all DDL and JCL files:</fo:inline>
                                                <fo:block>
                                                  <fo:table-and-caption border-collapse="collapse" space-before="1em" space-after="1em"><fo:table relative-align="baseline" chfox:html-table-width-policy="yes" table-layout="auto" hyphenate="true" id="unique_3_Connect_42_choicetable_frz_qjr_q3c" chfox:nd-id="choicetable_frz_qjr_q3c" space-before="0" space-after="0"><fo:table-column column-width="50%"/><fo:table-column column-width="50%"/><fo:table-header font-weight="bold" text-align="center" display-align="before">
                                                  <fo:table-row display-align="before">
                                                  <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em"><fo:block>Placeholder</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em"><fo:block>Description</fo:block></fo:table-cell>
                                                  </fo:table-row>
                                                  </fo:table-header><fo:table-body display-align="before">
                                                  <fo:table-row display-align="before">
                                                  <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" font-weight="bold" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" text-align="center"><fo:block>&lt;Your HLQ&gt;</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Your z/OS High-Level Qualifier</fo:block></fo:table-cell>
                                                  </fo:table-row>
                                                  <fo:table-row display-align="before">
                                                  <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" font-weight="bold" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" text-align="center"><fo:block>&lt;Your USERGRP&gt;</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Application user group for DML access</fo:block></fo:table-cell>
                                                  </fo:table-row>
                                                  <fo:table-row display-align="before">
                                                  <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" font-weight="bold" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" text-align="center"><fo:block>&lt;Your SSID&gt;</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="1px" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Db2 subsystem ID</fo:block></fo:table-cell>
                                                  </fo:table-row>
                                                  <fo:table-row display-align="before">
                                                  <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="0" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="1px" font-weight="bold" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" text-align="center"><fo:block>&lt;Your DB2HLQ&gt;</fo:block></fo:table-cell>
                                                  <fo:table-cell start-indent="0" end-indent="0" border-bottom-color="rgb(0 , 0 , 0)" border-bottom-style="solid" border-bottom-width="0" border-right-color="rgb(0 , 0 , 0)" border-right-style="solid" border-right-width="0" padding-bottom="0.3em" padding-left="0.3em" padding-right="0.3em" padding-top="0.3em" display-align="before"><fo:block>Db2 Software Library</fo:block></fo:table-cell>
                                                  </fo:table-row>
                                                  </fo:table-body></fo:table></fo:table-and-caption>
                                                </fo:block>
                                            </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">2. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                <fo:inline>Create an Initial Partitioned
                                                  Data Set (PDS) in <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your HLQ&gt;.ECOMAPP.ALOC</fo:inline>. You must
                                                  create one dataset and upload the <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">ECOMALOC.jcl</fo:inline> as a member of that
                                                  dataset.Your new dataset can be accessed by <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your HLQ&gt;.ECOMAPP.ALLOC(ECOMALOC)</fo:inline>.
                                                  Configure your new dataset with the appropriate
                                                  quantities, blocks, and record formattings below. </fo:inline>
                                                <fo:block>
                                                  <fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_3_Connect_42_codeblock_edw_lty_q3c" chfox:nd-id="codeblock_edw_lty_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Command ===&gt; A</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Dataset Name: &lt;Your HLQ&gt;.ECOMAPP.ECOMALOC</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Management class . . . &lt;blank&gt;</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Storage class  . . . . &lt;blank&gt;</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Volume serial  . . . . &lt;blank&gt;</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Device type  . . . . . &lt;blank or SYSDA&gt;</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Data class . . . . . . &lt;blank&gt;</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Space units  . . . . . TRKS</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Primary quantity . . . 5</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Secondary quantity . . 2</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Directory blocks . . . 2</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Record format  . . . . FB</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Record length  . . . . 80</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Block size . . . . . . 3120</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Data set name type . . PDS</fo:block></fo:block-container></fo:block></fo:block></fo:block-container>
                                                </fo:block>
                                                <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="0em" space-before="0em" id="unique_3_Connect_42_substeps_l5x_c5w_q3c" chfox:nd-id="substeps_l5x_c5w_q3c">
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">a. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Log into TSO/ISPF and
                                                  allocate the Initial PDS. </fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">b. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Upload ECOMALOC.jcl via Zowe
                                                  or by pasting in the code in ISPF. You can find
                                                  and edit it by using option 3.4 to find <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your
                                                  HLQ&gt;.ECOMAPP.ALLOC(ECOMALLOC)</fo:inline>.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                </fo:list-block>
                                            </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">3. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                <fo:inline>Run ECOMALOC to create DDL
                                                  and JCL libraries. This job creates the two main
                                                  PDS libraries for the DDL and JCL files. </fo:inline>
                                                <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="0em" space-before="0em" id="unique_3_Connect_42_substeps_s1s_ytw_q3c" chfox:nd-id="substeps_s1s_ytw_q3c">
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">a. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Insert option 3.4 in
                                                  DSLIST.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">b. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Navigate to <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your
                                                  HLQ&gt;.ECOMAPP.ALLOC(ECOMALOC)</fo:inline>.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">c. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Type <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">SUB</fo:inline> next to the ECOMALOC member.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">d. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Click Enter.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                </fo:list-block>
                                            </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">4. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                <fo:inline>Upload all SQL DDL files to
                                                  the <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your HLQ&gt;.ECOMAPP.DDL</fo:inline> library. You
                                                  can use Zowe to upload members directly from the
                                                  project repository into the dataset.</fo:inline>
                                                <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="0em" space-before="0em" id="unique_3_Connect_42_substeps_cl4_ttw_q3c" chfox:nd-id="substeps_cl4_ttw_q3c">
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">a. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Insert option 3.4 in
                                                  DSLIST.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">b. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Navigate to <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your HLQ&gt;.ECOMAPP.DDL</fo:inline>.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">c. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Click Enter.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">d. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Navigate to the ISPF main
                                                  menu and insert Option 2.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">e. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Insert <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your
                                                  HLQ&gt;.ECOMAPP.DDL(&lt;membername&gt;)</fo:inline>.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">f. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Paste in the new member
                                                  contents.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                </fo:list-block>
                                            </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">5. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                <fo:inline>Upload all JCL job files to
                                                  the <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your HLQ&gt;.ECOMAPP.JCL</fo:inline> library using
                                                  TSO/ISPF. </fo:inline>
                                                <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="0em" space-before="0em" id="unique_3_Connect_42_substeps_scq_ktw_q3c" chfox:nd-id="substeps_scq_ktw_q3c">
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">a. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Insert option 3.4 in
                                                  DSLIST.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">b. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Navigate to <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your HLQ&gt;.ECOMAPP.JCL</fo:inline>.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">c. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Click Enter.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">d. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Navigate to the ISPF main
                                                  menu and insert Option 2.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">e. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Insert <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your
                                                  HLQ&gt;.ECOMAPP.DDL(&lt;membername&gt;)</fo:inline>.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">f. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Paste in the new member
                                                  contents.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                </fo:list-block>
                                            </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">6. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                <fo:inline>Submit the ECOMDDL job to
                                                  create the database. Submit an ECOMDDL Job in
                                                  TSO/ISPF.</fo:inline>
                                                <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="0em" space-before="0em" id="unique_3_Connect_42_substeps_m1q_2tw_q3c" chfox:nd-id="substeps_m1q_2tw_q3c">
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">a. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Insert option 3.4 in
                                                  DSLIST.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">b. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Navigate to <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your HLQ&gt;.ECOMAPP.JCL</fo:inline>.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">c. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Insert <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">B</fo:inline> for browsing to see the members.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">d. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Type <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">SUB</fo:inline> next to the ECOMDDL member.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">e. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Click Enter</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                </fo:list-block>
                                            </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">7. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                <fo:inline>Verify the database creation
                                                  in TSO/ISPF. </fo:inline>
                                                <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="0em" space-before="0em" id="unique_3_Connect_42_substeps_y5h_m5w_q3c" chfox:nd-id="substeps_y5h_m5w_q3c">
                                                  <fo:list-item space-after="1em" space-before="1em"><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">a. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Insert option 2 in
                                                  SPUFI.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item space-after="1em" space-before="1em"><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">b. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                  <fo:inline>Enter <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">SELECT * FROM SYSIBM.SYSTABLES WHERE CREATOR =
                                                  '&lt;Your HLQ&gt;';</fo:inline>.</fo:inline>
                                                  <fo:block>The result will show all of
                                                  the tables in the database.</fo:block>
                                                  </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                                </fo:list-block>
                                            </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">8. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                <fo:inline>Initialize the Product
                                                  catalog by submitting an ECPMINIT Job in
                                                  TSO/ISPF.</fo:inline>
                                                <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="0em" space-before="0em" id="unique_3_Connect_42_substeps_qpk_mfs_q3c" chfox:nd-id="substeps_qpk_mfs_q3c">
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">a. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Navigate to <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your HLQ&gt;.ECOMAPP.JCL</fo:inline>.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">b. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Type <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">SUB</fo:inline>next to ECOMINIT member.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                </fo:list-block>
                                            </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">9. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                <fo:inline>Run statistics for optimal
                                                  query performance by running ECOMRS.</fo:inline>
                                                <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="0em" space-before="0em" id="unique_3_Connect_42_substeps_u5f_hfs_q3c" chfox:nd-id="substeps_u5f_hfs_q3c">
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">a. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Navigate to <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">&lt;Your HLQ&gt;.ECOMAPP.JCL</fo:inline>.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">b. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Type <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">SUB</fo:inline> next to ECOMRS member.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">c. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Check the job output in SDSF
                                                  job status menu.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                </fo:list-block>
                                            </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                        </fo:list-block>
                                    </fo:block>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_4" xml:lang="en" chfox:nd-id="modifyingthedatabase">
                                <fo:block-container font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid" id="ariaid-title4"><fo:block end-indent="0" start-indent="0" role="H2"><fo:inline>Adding tables to the ECOMAPP
                                        Database</fo:inline></fo:block></fo:block-container>
                                
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="0.5em"><fo:block end-indent="0" start-indent="0">In the ECOMAPP
                                        database you can add new tables by using TSO/ISPF in the Db2
                                        z/OS platform. </fo:block></fo:block-container>
                                    <fo:block-container space-after="1em" space-before="1em"><fo:block end-indent="0" start-indent="0" role="Sect"/></fo:block-container>
                                    <fo:block-container space-after="1em" space-before="1em"><fo:block end-indent="0" start-indent="0" role="Sect"/></fo:block-container>
                                    <fo:block role="Sect">
                                        <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em">
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">1. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block><fo:block-container><fo:block start-indent="0" end-indent="0">
                                                <fo:inline>Update EO3TABLE.sql</fo:inline>
                                                <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="0em" space-before="0em">
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">a. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Add <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">CREATE TABLE</fo:inline> statement.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">b. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Add <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">CREATE UNIQUE INDEX</fo:inline> for the primary
                                                  key.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                  <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">c. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                  <fo:inline>Add foreign key constraints
                                                  if applicable.</fo:inline>
                                                  </fo:block></fo:list-item-body></fo:list-item>
                                                </fo:list-block>
                                            </fo:block></fo:block-container></fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">2. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                <fo:inline>Update E04INDEX.sql</fo:inline>
                                            </fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">3. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                <fo:inline>Add performance indexes for
                                                  new table in E04INDEX.sql.</fo:inline>
                                            </fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">4. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                <fo:inline>Update E05CMNT.sql by adding
                                                  a <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">COMMENT</fo:inline> statement for the new table and
                                                  columns.</fo:inline>
                                            </fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">5. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                <fo:inline>Add <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">COMMENT</fo:inline> statements for new tables and
                                                  columns in E05CMNT.sql.</fo:inline>
                                            </fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">6. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                <fo:inline>Update E06GRANT.sql by adding
                                                  a <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">GRANT</fo:inline> statement for the new table.</fo:inline>
                                            </fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">7. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                <fo:inline>Update E07LOAD.sql by adding
                                                  an <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">INSERT</fo:inline> statement for the test data.</fo:inline>
                                            </fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">8. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                <fo:inline>Update ECOMDROP.jcl by adding
                                                  a <fo:inline background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" role="Code" padding-bottom="2px" padding-left="0" padding-right="0" padding-top="2px">DROP TABLE</fo:inline> statement.</fo:inline>
                                            </fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">9. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                <fo:inline>Re-upload and re-run.</fo:inline>
                                            </fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">10. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                <fo:inline>Upload all the modified DDL
                                                  files.</fo:inline>
                                            </fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end">11. </fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>
                                                <fo:inline>Submit ECOMDROP and
                                                  ECOMDDL.</fo:inline>
                                            </fo:block></fo:list-item-body></fo:list-item>
                                        </fo:list-block>
                                    </fo:block>
                                </fo:block></fo:block-container>
                            </fo:block>
                            <fo:block role="Sect" id="unique_5" xml:lang="en" chfox:nd-id="troubleshootingspectredb">
                                <fo:block-container font-size="1.7em" space-after="0.5em" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid" id="ariaid-title5"><fo:block end-indent="0" start-indent="0" role="H2"><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e890"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e894"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e898"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e902"/><fo:inline>Troubleshooting the NXTCG ECOMAPP
                                        database</fo:inline></fo:block></fo:block-container>
                                
                                <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                    <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="0.5em"><fo:block end-indent="0" start-indent="0">There are common
                                        SQL and API error codes when configuring the ECOMAPP
                                        database. Solutions are provided for each issue. </fo:block></fo:block-container>
                                    <fo:block>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-ecomddl-fails-with-rc12---plan-not-found" chfox:nd-id="issue-ecomddl-fails-with-rc12---plan-not-found"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1506" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>ECOMDDL Fails with RC=12 -
                                                  PLAN NOT FOUND</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> Db2 plan DSNTEP3 not available or
                                                no EXECUTE privilege.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_hjb_dl3_q3c" chfox:nd-id="codeblock_hjb_dl3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">1. Verify DSNTEP3 plan exists:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   -DIS THREAD(*) TYPE(PLAN)</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">2. Check your privileges:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   SELECT GRANTEE, GRANTEETYPE, AUTHHOWGOT</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   FROM SYSIBM.SYSPLANAUTH</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   WHERE NAME = 'DSNTEP3';</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">3. If missing privilege, have DBA grant:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   GRANT EXECUTE ON PLAN DSNTEP3 TO &lt;Your HLQ&gt;;</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-ecomddl-fails-with-rc12---sqlcode-204-object-not-found" chfox:nd-id="issue-ecomddl-fails-with-rc12---sqlcode-204-object-not-found"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1528" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>ECOMDDL Fails with RC=12 -
                                                  SQLCODE=-204 OBJECT NOT FOUND</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> DDL members not uploaded or
                                                incorrect dataset names.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_rmy_dl3_q3c" chfox:nd-id="codeblock_rmy_dl3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">1. Verify DDL members exist:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   TSO/ISPF 3.4 → &lt;Your HLQ&gt;.ECOMAPP.DDL</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">2. Check member names match exactly:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   E01STGDB, E02TBSPC, E03TABLE, E04INDEX, E05CMNT, E06GRANT</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   E07INIT1, E07INIT2, E07INIT3</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">3. Verify SET HLQ statement in ECOMDDL.jcl matches your dataset name</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-ecomddl-fails-with-rc8---sqlcode-601-object-already-exists" chfox:nd-id="issue-ecomddl-fails-with-rc8---sqlcode-601-object-already-exists"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1550" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>ECOMDDL Fails with RC=8 -
                                                  SQLCODE=-601 OBJECT ALREADY EXISTS</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> Database objects already
                                                exist.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_qp5_gl3_q3c" chfox:nd-id="codeblock_qp5_gl3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">This is expected behavior when re-running ECOMDDL on existing database.</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Job will continue and create any missing objects.</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">To start fresh:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">1. Submit ECOMDROP first</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">2. Then submit ECOMDDL</fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-ecominit-fails-with-rc12---rest-api-failure-with-https-status-500" chfox:nd-id="issue-ecominit-fails-with-rc12---rest-api-failure-with-https-status-500"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1572" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>ECOMINIT Fails with RC=12 -
                                                  Rest API failure with HTTP(S) status
                                                500</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> SQL files have lines exceeding 72
                                                characters.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_nm5_3l3_q3c" chfox:nd-id="codeblock_nm5_3l3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">All E07INIT files in zOS_Datasets have been pre-processed to comply</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">with 72-character line limits. If you modified them:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">1. Check for long lines:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   Edit member with ISPF</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   COLS ON (show column numbers)</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   Look for lines extending past column 72</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">2. Split long lines:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   - Break INSERT statements after table name</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   - Continue column list on next line with leading spaces</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   - Ensure VALUES clause on separate line</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">3. Re-upload corrected members</fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-ecominit-fails-with-sqlcode-803-duplicate-key" chfox:nd-id="issue-ecominit-fails-with-sqlcode-803-duplicate-key"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1594" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>ECOMINIT Fails with
                                                  SQLCODE=-803 DUPLICATE KEY</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> Product catalog already
                                                loaded.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_aln_jl3_q3c" chfox:nd-id="codeblock_aln_jl3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">This is expected behavior with RC=8. Job continues to next step.</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Each step is conditioned on RC &lt; 12.</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">To reload catalog from scratch:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">1. Submit ECOMDROP first</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">2. Submit ECOMDDL</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">3. Submit ECOMINIT</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-ecominit-shows-wrong-row-counts" chfox:nd-id="issue-ecominit-shows-wrong-row-counts"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1617" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>ECOMINIT Shows Wrong Row
                                                  Counts</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> Previous data not cleared, or
                                                partial load.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_zyx_ml3_q3c" chfox:nd-id="codeblock_zyx_ml3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">-- Check current countsSELECT'PRODUCT_VARIANTS'AS TABLE_NAME,COUNT(*)AS COUNT</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">FROM&lt;Your HLQ&gt;.PRODUCT_VARIANTS;</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Expected: 4,824If count doesn't match:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">1. Submit ECOMDROP</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">2. Submit ECOMDDL</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">3. Submit ECOMINIT</fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-not-authorized-to-create-database" chfox:nd-id="issue-not-authorized-to-create-database"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1639" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>NOT AUTHORIZED TO CREATE
                                                  DATABASE</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> Insufficient Db2 privileges.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_wzg_4l3_q3c" chfox:nd-id="codeblock_wzg_4l3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">Contact your Db2 DBA to grant CREATEDB authority:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">GRANT CREATEDB ON SYSTEM TO &lt;Your HLQ&gt;;</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-joblib-libraries-not-found" chfox:nd-id="issue-joblib-libraries-not-found"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1661" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>JOBLIB Libraries Not
                                                  Found</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> Incorrect Db2 software library
                                                HLQ.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_jqz_4l3_q3c" chfox:nd-id="codeblock_jqz_4l3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">1. Find correct Db2 HLQ on your system:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   TSO/ISPF 3.4 → DSN* (or DSNV*)</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   Look for: SDSNLOAD, SDSNEXIT, RUNLIB.LOAD</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">2. Update JOBLIB statements in all JCL files:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   //JOBLIB   DD  DISP=SHR,DSN=&lt;Correct HLQ&gt;.SDSNEXIT</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   //         DD  DISP=SHR,DSN=&lt;Correct HLQ&gt;.SDSNLOAD</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   //         DD  DISP=SHR,DSN=&lt;Correct HLQ&gt;.RUNLIB.LOAD</fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-storage-group-not-defined" chfox:nd-id="issue-storage-group-not-defined"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1683" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>STORAGE GROUP NOT
                                                  DEFINED</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> E01STGDB.sql uses default storage
                                                group.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_rws_pl3_q3c" chfox:nd-id="codeblock_rws_pl3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">1. Find available storage groups:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   SELECT * FROM SYSIBM.SYSSTOGROUP;</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">2. Update E01STGDB.sql:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   CREATE DATABASE ECOMDB01</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">       STOGROUP &lt;Your STOGROUP&gt;</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">       BUFFERPOOL BP0</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">       ...</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-price-calculations-return-wrong-values" chfox:nd-id="issue-price-calculations-return-wrong-values"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1705" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>Price Calculations Return
                                                  Wrong Values</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> Query not joining to
                                                STYLE_MODIFIERS table.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_msj_ql3_q3c" chfox:nd-id="codeblock_msj_ql3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">-- Incorrect (missing PRICE_MULTIPLIER):SELECT PT.BASE_PRICE_CENTS</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">FROM PRODUCT_VARIANTS PV</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">INNERJOIN PRODUCT_TYPES PT ON...;-- Correct (includes multiplier):SELECT</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">    PT.BASE_PRICE_CENTS,</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">    SM.PRICE_MULTIPLIER,</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">    CAST(PT.BASE_PRICE_CENTS * SM.PRICE_MULTIPLIER ASINT)AS FINAL_PRICE</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">FROM PRODUCT_VARIANTS PV</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">INNERJOIN PRODUCT_TYPES PT ON...INNERJOIN STYLE_MODIFIERS SM</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">    ON PV.STYLE_CODE = SM.STYLE_CODE</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   AND PV.MODIFIER_CODE = SM.MODIFIER_CODE;</fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                        <fo:block-container space-after="1em" space-before="1em" id="unique_5_Connect_42_issue-performance-issues--slow-queries" chfox:nd-id="issue-performance-issues--slow-queries"><fo:block end-indent="0" start-indent="0" role="Sect">
                                            <fo:block-container id="d39e1727" font-size="1.17em" font-weight="700" space-after="0" margin-left="0" margin-right="0" space-before="1em" page-break-after="avoid"><fo:block end-indent="0" start-indent="0" role="H3"><fo:inline>Slow Queries</fo:inline></fo:block></fo:block-container>
                                            <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Cause:</fo:inline> Statistics not gathered or
                                                outdated.</fo:block></fo:block-container>
                                            <fo:block-container space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Solution:</fo:inline><fo:block-container background-color="rgb(238 , 238 , 238)" font-family="monospace" font-size="0.8em" space-after="0.5em" margin-left="0.5em" margin-right="0" space-before="0.5em" max-height="600px" chfox:overflow-wrap="break-word" break-line-at-hyphens="avoid" padding-bottom="2px" padding-left="4px" padding-right="4px" padding-top="2px" linefeed-treatment="preserve" white-space-collapse="false" white-space-treatment="preserve" wrap-option="wrap" id="unique_5_Connect_42_codeblock_t2f_rl3_q3c" chfox:nd-id="codeblock_t2f_rl3_q3c"><fo:block end-indent="0" start-indent="0" role="Code"><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">1. Submit ECOMRS to gather/refresh statistics</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">2. Verify statistics exist:</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   SELECT NAME, CARD, NPAGES</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   FROM SYSIBM.SYSTABLES</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   WHERE CREATOR = '&lt;Your HLQ&gt;';</fo:block></fo:block-container></fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0"/></fo:block-container> </fo:block><fo:block><fo:block-container background-color="rgb(238 , 238 , 238)" font-size="0.8em" padding-bottom="0" padding-left="0" margin-left="0" padding-right="0" margin-right="0" padding-top="0"><fo:block end-indent="0" start-indent="0">   If CARD = -1, statistics not gathered</fo:block></fo:block-container></fo:block></fo:block></fo:block-container></fo:block></fo:block-container>
                                        </fo:block></fo:block-container>
                                    </fo:block>
                                </fo:block></fo:block-container>
                            </fo:block>
                        </fo:block></fo:block-container>
                    </fo:block>
                </fo:block></fo:block-container>
            </fo:block>
        </fo:block></fo:block-container>
    </fo:block></fo:block-container>
</fo:block></fo:flow></fo:page-sequence></fo:root>