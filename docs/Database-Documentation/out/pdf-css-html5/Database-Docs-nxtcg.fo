retrieve-boundary="document" retrieve-position="first-including-carryover"/><fo:retrieve-marker retrieve-class-name="sectiontitle" retrieve-boundary="document" retrieve-position="first-including-carryover"/> | <fo:page-number/></fo:block></fo:table-cell></fo:table-row></fo:table-body></fo:table></fo:static-content><fo:static-content flow-name="xsl-footnote-separator" role="artifact" text-align="left" display-align="auto" font-size="10pt" font-family="Roboto , sans-serif" border-top-style="solid" border-top-color="black" border-top-width="thin" padding-top="8pt"><fo:block/></fo:static-content><fo:flow flow-name="xsl-region-body"><fo:block font-family="serif" font-size="12px" min-width="100%" xml:lang="en"><fo:block-container font-family="Roboto, sans-serif" font-size="10pt" margin-left="0" margin-right="0" min-width="100%"><fo:block end-indent="0" start-indent="0"><fo:block-container color="rgb(0 , 0 , 0)" line-height="1.7em" space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block><fo:block-container space-after="80px"><fo:block end-indent="0" start-indent="0"><fo:block xml:lang="en"><fo:block-container space-before="1em" id="unique_1" xml:lang="en" chfox:nd-id="dbdocsconcept1"><fo:block end-indent="0" start-indent="0" role="Sect">
                            <fo:block-container font-size="2em" line-height="1.1em" space-after="0.5em" margin-left="0" margin-right="0" space-before="0" page-break-after="avoid" id="ariaid-title1"><fo:block end-indent="0" start-indent="0" role="H1"><fo:marker marker-class-name="chaptertitle-no-prefix"><fo:inline/> 1 - <!--content(text)--><fo:inline>Introduction to the NXTCG ECOMAPP Database</fo:inline></fo:marker><fo:marker marker-class-name="chaptertitle"><fo:inline/> | 1 - <!--content(text)--><fo:inline>Introduction to the NXTCG ECOMAPP Database</fo:inline></fo:marker><fo:inline>Chapter 1. </fo:inline><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e159"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e163"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e167"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e171"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e175"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e180"/><fo:inline background-color="transparent" color="transparent" font-size="0px" max-width="2px" vertical-align="super" id="d133e184"/><fo:inline>Introduction to the NXTCG ECOMAPP
                                    Database</fo:inline></fo:block></fo:block-container>
                            
                            <fo:block>
                                <fo:block>
                                    <fo:block-container space-after="0" margin-left="0" margin-right="0" space-before="0"><fo:block end-indent="0" start-indent="0">
                                        <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="0.5em"><fo:block end-indent="0" start-indent="0">The NextGen
                                            Trading Card Game (NXTCG) features exclusive collectible
                                            cards inspired by the Rocket Software NextGen Academy
                                            and its Rocketeers. The platform empowers you to buy and
                                            sell new NXTCG cards. Use this guide to install the
                                            NXTCG database, add tables, and troubleshoot common
                                            issues you may encounter. </fo:block></fo:block-container>
                                        <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0">ECOMAPP is a
                                            Db2 13 for z/OS database for NXTCG. It is compromised of
                                            15 normalized tables with full referential integrity and
                                            indexed access paths. Administration is driven by
                                            source-controlled DDL and JCL pipelines for build,
                                            initialization, statistics, grants, and teardown. </fo:block></fo:block-container>
                                        <fo:block-container space-after="0.5em" margin-left="0" margin-right="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="bold">Key Features:</fo:inline></fo:block></fo:block-container>
                                        <fo:list-block relative-align="baseline" provisional-label-separation="3pt" provisional-distance-between-starts="40px" space-after="1.33em" space-before="1.33em" id="unique_1_Connect_42_ul_fhm_zcd_q3c" chfox:nd-id="ul_fhm_zcd_q3c">
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end"><fo:inline font-family="Times New Roman,Liberation Serif,DejaVu Serif,Symbol,Segoe UI Symbol,FreeSerif,ZapfDingbats">• </fo:inline></fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Complete SKU-based product catalog (4,824 trading
                                                card variants)</fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end"><fo:inline font-family="Times New Roman,Liberation Serif,DejaVu Serif,Symbol,Segoe UI Symbol,FreeSerif,ZapfDingbats">• </fo:inline></fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Multiplier-based dynamic pricing system</fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end"><fo:inline font-family="Times New Roman,Liberation Serif,DejaVu Serif,Symbol,Segoe UI Symbol,FreeSerif,ZapfDingbats">• </fo:inline></fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>16
                                                normalized tables with full referential
                                                integrity</fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end"><fo:inline font-family="Times New Roman,Liberation Serif,DejaVu Serif,Symbol,Segoe UI Symbol,FreeSerif,ZapfDingbats">• </fo:inline></fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Performance indexes on all critical access
                                                paths</fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end"><fo:inline font-family="Times New Roman,Liberation Serif,DejaVu Serif,Symbol,Segoe UI Symbol,FreeSerif,ZapfDingbats">• </fo:inline></fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Split
                                                initialization files for mainframe line length
                                                compliance</fo:block></fo:list-item-body></fo:list-item>
                                            <fo:list-item><fo:list-item-label end-indent="label-end()"><fo:block text-align="end"><fo:inline font-family="Times New Roman,Liberation Serif,DejaVu Serif,Symbol,Segoe UI Symbol,FreeSerif,ZapfDingbats">• </fo:inline></fo:block></fo:list-item-label><fo:list-item-body start-indent="body-start()"><fo:block>Automated JCL for all database operations</fo:block></fo:list-item-body></fo:list-item>
                                        </fo:list-block>
                                    </fo:block></fo:block-container>
                                </fo:block>
                                <fo:block>
                                    <fo:block>
                                        <fo:block-container border-top-color="rgb(204 , 204 , 204)" border-top-style="solid" border-top-width="1px" space-before="0" padding-bottom="0.5em" padding-left="1.5em" margin-left="0" padding-right="1.5em" margin-right="0" padding-top="0.5em"><fo:block end-indent="0" start-indent="0">
                                            <fo:block-container space-after="0" margin-left="0" margin-right="1.5em" space-before="1em" padding-left="0"><fo:block end-indent="0" start-indent="0">
                                                
                                                <fo:block-container space-after="0" margin-left="0" space-before="0" padding-left="0"><fo:block end-indent="0" start-indent="0">
                                                  <fo:block-container space-after="1em" margin-left="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="700"><fo:inline color="rgb(81 , 133 , 203)"><fo:basic-link show-destination="new" indicate-destination="true" internal-destination="unique_2" fox:alt-text="ECOMAPP Database Architecture">ECOMAPP Database
                                                  Architecture</fo:basic-link></fo:inline></fo:inline></fo:block></fo:block-container>
                                                  <fo:block-container space-after="1em" margin-left="0" space-before="1em"><fo:block end-indent="0" start-indent="0"><fo:inline font-weight="700"><fo:inline color="rgb(81 , 133 , 203)"><fo:basic-link show-destination="new" indicate-destination="true" internal-destination="unique_3" fox:alt-text="Installing the ECOMAPP database">Installing the ECOMAPP
