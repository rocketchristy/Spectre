  <frontmatter class="- map/topicref bookmap/frontmatter " xtrc="frontmatter:1;38:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"><booklists class="- map/topicref bookmap/booklists " xtrc="booklists:1;39:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"><trademarklist class="- map/topicref bookmap/trademarklist " xtrc="trademarklist:1;40:24" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/><booklist class="- map/topicref bookmap/booklist " xtrc="booklist:1;41:19" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/><toc class="- map/topicref bookmap/toc " xtrc="toc:1;42:14" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/></booklists></frontmatter>
  <chapter class="- map/topicref bookmap/chapter " xtrc="chapter:1;46:46" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap" href="topics/dbdocsconcept1.dita" type="concept"><topicmeta class="- map/topicmeta " data-topic-id="dbdocsconcept1"><resourceid class="- topic/resourceid " oxy-source="topic" appid="dbdocsconcept1"/><navtitle class="- topic/navtitle ">Database Administrator Guide</navtitle><?ditaot gentext?><linktext class="- map/linktext ">Database Administrator Guide</linktext><?ditaot genshortdesc?><shortdesc class="- map/shortdesc ">The NextGen Trading Card Game features exclusive collectible cards inspired by the         Rocket Software NextGen Academy and its Rocketeers. The platform empowers users to buy and         sell new cards and related products, creating a dynamic marketplace for fans and         collectors.</shortdesc><critdates class="- topic/critdates " xtrc="critdates:1;12:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap">
      <created class="- topic/created " date="January 2017" xtrc="created:1;13:37" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/>
      
    </critdates></topicmeta><topicref class="- map/topicref " xtrc="topicref:1;47:70" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap" href="topics/database-administrator-guide-topic.dita" type="topic"><topicmeta class="- map/topicmeta " data-topic-id="dbdocstopic1"><resourceid class="- topic/resourceid " oxy-source="topic" appid="dbdocstopic1"/><navtitle class="- topic/navtitle ">ECOMAPP Database Architecture</navtitle><?ditaot gentext?><linktext class="- map/linktext ">ECOMAPP Database Architecture</linktext><?ditaot genshortdesc?><shortdesc class="- map/shortdesc "> Structural and logical architecture for the ECOMAPP NXTCG database on Db2 13 for         z/OS. The database design and architecture includes SKU composition, multiplier-based         pricing, and normalized entities with referential integrity.</shortdesc><critdates class="- topic/critdates " xtrc="critdates:1;12:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap">
      <created class="- topic/created " date="January 2017" xtrc="created:1;13:37" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/>
      
    </critdates></topicmeta></topicref><topicref class="- map/topicref " xtrc="topicref:2;48:49" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap" href="topics/installingdb2.dita" type="task"><topicmeta class="- map/topicmeta " data-topic-id="installingdb2"><resourceid class="- topic/resourceid " oxy-source="topic" appid="installingdb2"/><navtitle class="- topic/navtitle ">Installing ECOMAPP</navtitle><?ditaot gentext?><linktext class="- map/linktext ">Installing ECOMAPP</linktext><?ditaot genshortdesc?><shortdesc class="- map/shortdesc ">ECOMAPP database is hosted on Db2 for z/OS platform. Installing ECOMAPP requires you to       have a Db2 license called Db2 Connect in order for you to make a connection from the NXTCG       backend application.</shortdesc><critdates class="- topic/critdates " xtrc="critdates:1;12:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap">
      <created class="- topic/created " date="January 2017" xtrc="created:1;13:37" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/>
      
    </critdates></topicmeta></topicref><topicref class="- map/topicref " xtrc="topicref:3;49:60" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap" href="topics/troubleshootingspectredb.dita" type="topic"><topicmeta class="- map/topicmeta " data-topic-id="troubleshootingspectredb"><resourceid class="- topic/resourceid " oxy-source="topic" appid="troubleshootingspectredb"/><navtitle class="- topic/navtitle ">Troubleshooting the NXTCG ECOMAPP database</navtitle><?ditaot gentext?><linktext class="- map/linktext ">Troubleshooting the NXTCG ECOMAPP database</linktext><?ditaot genshortdesc?><shortdesc class="- map/shortdesc ">There are common SQL and API error codes when configuring the ECOMAPP database. Solutions         are provided for each issue.  </shortdesc><critdates class="- topic/critdates " xtrc="critdates:1;12:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap">
      <created class="- topic/created " date="January 2017" xtrc="created:1;13:37" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/>
      
    </critdates></topicmeta></topicref></chapter>
  
  
  <backmatter class="- map/topicref bookmap/backmatter " xtrc="backmatter:1;53:15" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"><booklists class="- map/topicref bookmap/booklists " xtrc="booklists:2;54:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"><indexlist class="- map/topicref bookmap/indexlist " xtrc="indexlist:1;55:20" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/><trademarklist class="- map/topicref bookmap/trademarklist " xtrc="trademarklist:2;56:24" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/><booklist class="- map/topicref bookmap/booklist " xtrc="booklist:2;57:19" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/></booklists></backmatter>
