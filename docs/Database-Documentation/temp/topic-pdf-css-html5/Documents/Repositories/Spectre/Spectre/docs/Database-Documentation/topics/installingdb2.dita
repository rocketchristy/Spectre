<taskbody class="- topic/body task/taskbody " xtrc="taskbody:1;10:11" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/installingdb2.dita">
<prereq class="- topic/section task/prereq " xtrc="prereq:1;11:9" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/installingdb2.dita">
         <p class="- topic/p " xtrc="p:1;12:13" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/installingdb2.dita">Before installing ECOMAPP, you must have these requirements: </p>
         <ul class="- topic/ul " id="ul_ncw_xcd_q3c" xtrc="ul:1;13:34" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/installingdb2.dita">
            <li class="- topic/li " xtrc="li:1;14:17" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/installingdb2.dita">Access: You must have access to TSO/ISPF. </li>
            <li class="- topic/li " xtrc="li:2;15:17" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/installingdb2.dita">Db2: Version 13, subsystem ID <codeph class="+ topic/ph pr-d/codeph " xtrc="codeph:1;15:55" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/installingdb2.dita">&lt;Your SSID&gt;</codeph>, Db2 software HLQ
                  <codeph class="+ topic/ph pr-d/codeph " xtrc="codeph:2;16:27" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/installingdb2.dita">&lt;Your DB2HLQ&gt;</codeph>, and a Db2 Connect license.</li>
            <li class="- topic/li " xtrc="li:3;17:17" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/installingdb2.dita">User Privileges: SYSADM/SYSCTRL or CREATEDB.</li>
            <li class="- topic/li " xtrc="li:4;18:17" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/installingdb2.dita">Storage: 100 tracks for DDL library, 50 tracks for JCL library, 500 MB DASD for
               tablespaces and indexes.</li>
         </ul>
      </prereq>
