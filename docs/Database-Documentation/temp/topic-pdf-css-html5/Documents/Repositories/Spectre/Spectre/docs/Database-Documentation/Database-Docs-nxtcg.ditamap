  <frontmatter class="- map/topicref bookmap/frontmatter " xtrc="frontmatter:1;37:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"><booklists class="- map/topicref bookmap/booklists " xtrc="booklists:1;38:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"><trademarklist class="- map/topicref bookmap/trademarklist " xtrc="trademarklist:1;39:24" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/><booklist class="- map/topicref bookmap/booklist " xtrc="booklist:1;40:19" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/><toc class="- map/topicref bookmap/toc " xtrc="toc:1;41:14" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/></booklists></frontmatter>
  <chapter class="- map/topicref bookmap/chapter " xtrc="chapter:1;44:46" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap" href="topics/dbdocsconcept1.dita" type="concept"><topicmeta class="- map/topicmeta " data-topic-id="dbdocsconcept1"><resourceid class="- topic/resourceid " oxy-source="topic" appid="dbdocsconcept1"/><navtitle class="- topic/navtitle ">Introduction to the NXTCG ECOMAPP Database</navtitle><?ditaot gentext?><linktext class="- map/linktext ">Introduction to the NXTCG ECOMAPP Database</linktext><?ditaot genshortdesc?><shortdesc class="- map/shortdesc ">The NextGen Trading Card Game (NXTCG) features exclusive collectible cards inspired         by the Rocket Software NextGen Academy and its Rocketeers. The platform empowers you to buy         and sell new NXTCG cards. Use this guide to install the NXTCG database, add tables, and         troubleshoot common issues you may encounter. </shortdesc><critdates class="- topic/critdates " xtrc="critdates:1;11:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap">
      <created class="- topic/created " date="January 2017" xtrc="created:1;12:37" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/>
      
    </critdates></topicmeta><topicref class="- map/topicref " xtrc="topicref:1;45:70" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap" href="topics/database-administrator-guide-topic.dita" type="topic"><topicmeta class="- map/topicmeta " data-topic-id="dbdocstopic1"><resourceid class="- topic/resourceid " oxy-source="topic" appid="dbdocstopic1"/><navtitle class="- topic/navtitle ">ECOMAPP Database Architecture</navtitle><?ditaot gentext?><linktext class="- map/linktext ">ECOMAPP Database Architecture</linktext><?ditaot genshortdesc?><shortdesc class="- map/shortdesc ">The database design and architecture includes SKU composition, multiplier-based         pricing, and normalized entities with referential integrity. NXTCG ECOMAPP's database is         hosted on Db2 13 for z/OS.</shortdesc><critdates class="- topic/critdates " xtrc="critdates:1;11:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap">
      <created class="- topic/created " date="January 2017" xtrc="created:1;12:37" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/>
      
    </critdates></topicmeta></topicref><topicref class="- map/topicref " xtrc="topicref:2;46:49" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap" href="topics/installingdb2.dita" type="task"><topicmeta class="- map/topicmeta " data-topic-id="installingdb2"><resourceid class="- topic/resourceid " oxy-source="topic" appid="installingdb2"/><navtitle class="- topic/navtitle ">Installing the ECOMAPP database</navtitle><?ditaot gentext?><linktext class="- map/linktext ">Installing the ECOMAPP database</linktext><?ditaot genshortdesc?><shortdesc class="- map/shortdesc ">ECOMAPP database is hosted on Db2 for z/OS platform. You can install the ECOMAPP database       within TSO/ISPF.</shortdesc><critdates class="- topic/critdates " xtrc="critdates:1;11:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap">
      <created class="- topic/created " date="January 2017" xtrc="created:1;12:37" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/>
      
    </critdates></topicmeta></topicref><topicref class="- map/topicref " xtrc="topicref:3;47:56" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap" href="topics/modifyingthedatabase.dita" type="task"><topicmeta class="- map/topicmeta " data-topic-id="modifyingthedatabase"><resourceid class="- topic/resourceid " oxy-source="topic" appid="modifyingthedatabase"/><navtitle class="- topic/navtitle ">Adding tables to the ECOMAPP Database</navtitle><?ditaot gentext?><linktext class="- map/linktext ">Adding tables to the ECOMAPP Database</linktext><?ditaot genshortdesc?><shortdesc class="- map/shortdesc ">In the ECOMAPP database you can add new tables by using TSO/ISPF in the Db2 z/OS       platform. </shortdesc><critdates class="- topic/critdates " xtrc="critdates:1;11:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap">
      <created class="- topic/created " date="January 2017" xtrc="created:1;12:37" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/>
      
    </critdates></topicmeta></topicref><topicref class="- map/topicref " xtrc="topicref:4;48:60" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap" href="topics/troubleshootingspectredb.dita" type="topic"><topicmeta class="- map/topicmeta " data-topic-id="troubleshootingspectredb"><resourceid class="- topic/resourceid " oxy-source="topic" appid="troubleshootingspectredb"/><navtitle class="- topic/navtitle ">Troubleshooting the NXTCG ECOMAPP database</navtitle><?ditaot gentext?><linktext class="- map/linktext ">Troubleshooting the NXTCG ECOMAPP database</linktext><?ditaot genshortdesc?><shortdesc class="- map/shortdesc ">There are common SQL and API error codes when configuring the ECOMAPP database. Solutions         are provided for each issue.  </shortdesc><critdates class="- topic/critdates " xtrc="critdates:1;11:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap">
      <created class="- topic/created " date="January 2017" xtrc="created:1;12:37" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/>
      
    </critdates></topicmeta></topicref></chapter>
  <backmatter class="- map/topicref bookmap/backmatter " xtrc="backmatter:1;50:15" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"><booklists class="- map/topicref bookmap/booklists " xtrc="booklists:2;51:16" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"><trademarklist class="- map/topicref bookmap/trademarklist " xtrc="trademarklist:2;52:24" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/><booklist class="- map/topicref bookmap/booklist " xtrc="booklist:2;53:19" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/Database-Docs-nxtcg.ditamap"/></booklists></backmatter>
