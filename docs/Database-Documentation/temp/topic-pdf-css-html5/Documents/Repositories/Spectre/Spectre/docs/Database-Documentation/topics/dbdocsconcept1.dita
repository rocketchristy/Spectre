    <conbody class="- topic/body  concept/conbody " xtrc="conbody:1;24:14" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/dbdocsconcept1.dita">
        <p class="- topic/p " xtrc="p:1;25:12" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/dbdocsconcept1.dita">ECOMAPP is a Db2 13 for z/OS database for NXTCG. It is compromised of 15 normalized
            tables with full referential integrity and indexed access paths. Administration is
            driven by source-controlled DDL and JCL pipelines for build, initialization, statistics,
            grants, and teardown. </p>
        <p class="- topic/p " xtrc="p:2;29:12" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/dbdocsconcept1.dita"><b class="+ topic/ph hi-d/b " xtrc="b:1;29:15" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/dbdocsconcept1.dita">Key Features:</b></p>
        <ul class="- topic/ul " id="ul_fhm_zcd_q3c" xtrc="ul:1;30:33" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/dbdocsconcept1.dita">
            <li class="- topic/li " xtrc="li:1;31:17" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/dbdocsconcept1.dita">Complete SKU-based product catalog (4,824 trading card variants)</li>
            <li class="- topic/li " xtrc="li:2;32:17" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/dbdocsconcept1.dita">Multiplier-based dynamic pricing system</li>
            <li class="- topic/li " xtrc="li:3;33:17" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/dbdocsconcept1.dita">16 normalized tables with full referential integrity</li>
            <li class="- topic/li " xtrc="li:4;34:17" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/dbdocsconcept1.dita">Performance indexes on all critical access paths</li>
            <li class="- topic/li " xtrc="li:5;35:17" xtrf="file:/C:/Users/jheckel/Documents/Repositories/Spectre/Spectre/docs/Database-Documentation/topics/dbdocsconcept1.dita">Split initialization files for mainframe line length compliance</li>
