    @pytest.mark.unit
    def test_add_item_success(self, cart_dao, mock_connection_pool):
        """Test adding item to cart - verifies all parameter bindings"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            
            result = cart_dao.add_item(
                cart_id=1,
                inventory_id=5,
                quantity=2,
                unit_price_cents=9999,
                currency_code='USD'
            )
            
            assert result['status'] == 'success'
            
            # Verify SQL structure
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'INSERT INTO USER01.CART_ITEMS' in sql_call
            assert 'CART_ID' in sql_call
            assert 'INVENTORY_ID' in sql_call
            assert 'QUANTITY' in sql_call
            assert 'UNIT_PRICE_CENTS' in sql_call
            assert 'CURRENCY_CODE' in sql_call
            
            # Verify all parameters bound in correct order
            expected_calls = [
                call(mock_stmt, 1, 1),      # cart_id
                call(mock_stmt, 2, 5),      # inventory_id
                call(mock_stmt, 3, 2),      # quantity
                call(mock_stmt, 4, 9999),   # unit_price_cents
                call(mock_stmt, 5, 'USD'),  # currency_code
            ]
            mock_db.bind_param.assert_has_calls(expected_calls, any_order=False)
            
            # Verify transaction management
            mock_db.execute.assert_called_once_with(mock_stmt)
            mock_db.commit.assert_called_once_with(mock_conn)
            mock_connection_pool.return_connection.assert_called_once()

    @pytest.mark.unit
    @pytest.mark.parametrize("quantity,price,currency", [
        (1, 100, 'USD'),           # Minimum quantity
        (999, 999999, 'USD'),      # Large values
        (0, 0, 'USD'),             # Zero edge case (should succeed at DAO level)
        (-1, -100, 'USD'),         # Negative edge case (should succeed at DAO level)
        (1, 100, 'EUR'),           # Different currency
        (1, 100, 'JPY'),           # Another currency
    ])
    def test_add_item_edge_cases(self, cart_dao, mock_connection_pool, quantity, price, currency):
        """Test adding items with various edge case values"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            
            result = cart_dao.add_item(1, 5, quantity, price, currency)
            
            assert result['status'] == 'success'
            # Verify the values were passed correctly
            calls = mock_db.bind_param.call_args_list
            assert calls[2] == call(mock_stmt, 3, quantity)
            assert calls[3] == call(mock_stmt, 4, price)
            assert calls[4] == call(mock_stmt, 5, currency)

    @pytest.mark.unit
    def test_add_item_error_with_rollback(self, cart_dao, mock_connection_pool):
        """Test error handling when adding item - verifies rollback"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_db.prepare.side_effect = Exception("Duplicate entry")
            
            result = cart_dao.add_item(1, 5, 2, 9999, 'USD')
            
            assert result['status'] == 'error'
            assert 'Duplicate entry' in str(result['reason'])
            
            # Verify rollback called
            mock_db.rollback.assert_called_once_with(mock_conn)
            
            # Verify commit never called
            mock_db.commit.assert_not_called()
            
            # Verify connection returned
            mock_connection_pool.return_connection.assert_called_once()

    @pytest.mark.unit
    def test_remove_item_success(self, cart_dao, mock_connection_pool):
        """Test removing item from cart - verifies deletion and row count check"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.num_rows.return_value = 1
            
            result = cart_dao.remove_item(cart_id=1, cart_item_id=5)
            
            assert result['status'] == 'success'
            
            # Verify SQL structure
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'DELETE FROM USER01.CART_ITEMS' in sql_call
            assert 'CART_ID' in sql_call
            assert 'ID' in sql_call  # cart_item_id
            
            # Verify parameters
            expected_calls = [
                call(mock_stmt, 1, 1),  # cart_id
                call(mock_stmt, 2, 5),  # cart_item_id
            ]
            mock_db.bind_param.assert_has_calls(expected_calls)
            
            # Verify execution and commit
            mock_db.execute.assert_called_once()
            mock_db.num_rows.assert_called_once_with(mock_stmt)
            mock_db.commit.assert_called_once_with(mock_conn)

    @pytest.mark.unit
    def test_remove_item_not_found(self, cart_dao, mock_connection_pool):
        """Test removing item when it doesn't exist - should return error"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.num_rows.return_value = 0  # No rows affected
            
            result = cart_dao.remove_item(1, 5)
            
            assert result['status'] == 'error'
            assert 'not found' in result['reason'].lower()
            
            # Verify no commit when item not found
            mock_db.commit.assert_not_called()
    
    @pytest.mark.unit
    def test_remove_item_wrong_cart(self, cart_dao, mock_connection_pool):
        """Test removing item from wrong cart (security check)"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.num_rows.return_value = 0  # Item exists but not in this cart
            
            result = cart_dao.remove_item(cart_id=999, cart_item_id=5)
            
            # Should fail - protecting against removing items from other users' carts
            assert result['status'] == 'error'

    @pytest.mark.unit
    def test_remove_entire_cart_with_items(self, cart_dao, mock_connection_pool):
        """Test clearing all items from cart - verifies bulk delete"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.num_rows.return_value = 3
            
            result = cart_dao.remove_entire_cart(1)
            
            assert result['status'] == 'success'
            assert result['rows_deleted'] == 3
            
            # Verify SQL structure
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'DELETE FROM USER01.CART_ITEMS' in sql_call
            assert 'CART_ID' in sql_call
            
            # Verify parameter binding
            mock_db.bind_param.assert_called_once_with(mock_stmt, 1, 1)
            
            # Verify transaction
            mock_db.execute.assert_called_once()
            mock_db.commit.assert_called_once_with(mock_conn)

    @pytest.mark.unit
    def test_remove_entire_cart_already_empty(self, cart_dao, mock_connection_pool):
        """Test error when cart is already empty"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.num_rows.return_value = 0
            
            result = cart_dao.remove_entire_cart(1)
            
            assert result['status'] == 'error'
            assert 'empty' in result['reason'].lower()
            
            # Should not commit when nothing to delete
            mock_db.commit.assert_not_called()
    
    @pytest.mark.unit
    @pytest.mark.parametrize("num_items", [1, 5, 100, 1000])
    def test_remove_entire_cart_various_sizes(self, cart_dao, mock_connection_pool, num_items):
        """Test clearing carts of various sizes"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.num_rows.return_value = num_items
            
            result = cart_dao.remove_entire_cart(1)
            
            assert result['status'] == 'success'
            assert result['rows_deleted'] == num_items


# ============================================================================
# USE CASE TESTS - Testing business scenarios, not just individual methods
# ============================================================================

@pytest.mark.unit
@pytest.mark.integration
class TestCartUseCases:
    """Test real-world cart usage scenarios"""
    
    def test_complete_cart_lifecycle(self, cart_dao, mock_connection_pool):
        """
        USE CASE: Complete cart flow
        1. Create cart for new user
        2. Add multiple items
        3. Remove one item
        4. Clear entire cart
        """
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            
            # Step 1: Create cart
            mock_db.num_rows.return_value = 1
            result1 = cart_dao.create_cart(user_id=123)
            assert result1['status'] == 'success'
            
            # Step 2: Add items
            result2 = cart_dao.add_item(1, 10, 2, 9999, 'USD')
            assert result2['status'] == 'success'
            
            result3 = cart_dao.add_item(1, 20, 1, 15999, 'USD')
            assert result3['status'] == 'success'
            
            # Step 3: Remove one item
            result4 = cart_dao.remove_item(1, 10)
            assert result4['status'] == 'success'
            
            # Step 4: Clear cart
            result5 = cart_dao.remove_entire_cart(1)
            assert result5['status'] == 'success'
    
    def test_abandoned_cart_scenario(self, cart_dao, mock_connection_pool):
        """
        USE CASE: User adds items but never checks out
        Verify we can retrieve cart later
        """
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            
            # Add items
            cart_dao.add_item(1, 5, 3, 5999, 'USD')
            
            # Later: retrieve cart
            mock_db.fetch_assoc.side_effect = [
                {'CART_ITEM_ID': 1, 'SKU': '001', 'QUANTITY': 3},
                None
            ]
            result = cart_dao.get_cart(user_id=123)
            
            assert result['status'] == 'success'
            assert len(result['output']) == 1


