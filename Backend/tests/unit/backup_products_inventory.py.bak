    @pytest.mark.unit
    def test_add_order_success(self, orders_dao, mock_connection_pool):
        """Test creating new order - verifies parameter binding and defaults"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            
            result = orders_dao.add_order(
                user_id=123,
                currency_code='USD',
                subtotal_cents=15997,
                billing_address_id=1,
                shipping_address_id=2
            )
            
            assert result['status'] == 'success'
            
            # Verify SQL structure
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'INSERT INTO USER01.ORDERS' in sql_call
            assert 'USER_ID' in sql_call
            assert 'SUBTOTAL_CENTS' in sql_call
            assert 'TOTAL_CENTS' in sql_call
            assert 'TAX_CENTS' in sql_call
            assert 'SHIPPING_CENTS' in sql_call
            assert 'DISCOUNT_CENTS' in sql_call
            
            # Verify all parameters bound correctly
            expected_calls = [
                call(mock_stmt, 1, 123),     # user_id
                call(mock_stmt, 2, 'USD'),   # currency_code
                call(mock_stmt, 3, 15997),   # subtotal_cents
                call(mock_stmt, 4, 15997),   # total_cents (same as subtotal initially)
                call(mock_stmt, 5, 1),       # billing_address_id
                call(mock_stmt, 6, 2),       # shipping_address_id
            ]
            mock_db.bind_param.assert_has_calls(expected_calls, any_order=False)
            
            # Verify transaction
            mock_db.execute.assert_called_once()
            mock_db.commit.assert_called_once_with(mock_conn)
    
    @pytest.mark.unit
    @pytest.mark.parametrize("subtotal,currency", [
        (100, 'USD'),
        (999999, 'EUR'),
        (1, 'JPY'),
        (0, 'USD'),  # Edge case: free order
    ])
    def test_add_order_various_amounts(self, orders_dao, mock_connection_pool, subtotal, currency):
        """Test creating orders with various subtotals and currencies"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            
            result = orders_dao.add_order(123, currency, subtotal, 1, 2)
            
            assert result['status'] == 'success'
            # Verify subtotal parameter
            calls = mock_db.bind_param.call_args_list
            assert calls[2] == call(mock_stmt, 3, subtotal)
            assert calls[1] == call(mock_stmt, 2, currency)

    @pytest.mark.unit
    def test_add_order_error_with_rollback(self, orders_dao, mock_connection_pool):
        """Test error handling when creating order - verifies rollback"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_db.prepare.side_effect = Exception("Foreign key constraint")
            
            result = orders_dao.add_order(123, 'USD', 15997, 1, 2)
            
            assert result['status'] == 'error'
            assert 'Foreign key constraint' in str(result['reason'])
            
            # Verify rollback
            mock_db.rollback.assert_called_once_with(mock_conn)
            mock_db.commit.assert_not_called()

    @pytest.mark.unit
    def test_add_order_item_success(self, orders_dao, mock_connection_pool):
        """Test adding item to order - verifies all 8 parameters"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            
            result = orders_dao.add_order_item(
                order_id=101,
                inventory_id=5,
                seller_id=1,
                sku='001ST001SN001A',
                product_name='Premium Watch',
                unit_price_cents=9999,
                currency_code='USD',
                quantity=2
            )
            
            assert result['status'] == 'success'
            
            # Verify SQL structure
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'INSERT INTO USER01.ORDER_ITEMS' in sql_call
            
            # Verify all 9 parameters bound (including total_cents)
            expected_calls = [
                call(mock_stmt, 1, 101),                # order_id
                call(mock_stmt, 2, 5),                  # inventory_id
                call(mock_stmt, 3, 1),                  # seller_id
                call(mock_stmt, 4, '001ST001SN001A'),   # sku
                call(mock_stmt, 5, 'Premium Watch'),    # product_name
                call(mock_stmt, 6, 9999),               # unit_price_cents
                call(mock_stmt, 7, 'USD'),              # currency_code
                call(mock_stmt, 8, 2),                  # quantity
                call(mock_stmt, 9, 19998),              # total_cents (9999 * 2)
            ]
            mock_db.bind_param.assert_has_calls(expected_calls, any_order=False)
            assert mock_db.bind_param.call_count == 9
            
            # Verify transaction
            mock_db.execute.assert_called_once()
            mock_db.commit.assert_called_once()

    @pytest.mark.unit
    def test_add_order_item_with_long_product_name(self, orders_dao, mock_connection_pool):
        """Test adding order item with very long product name (edge case)"""
