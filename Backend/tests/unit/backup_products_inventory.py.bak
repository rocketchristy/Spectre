    @pytest.mark.unit
    def test_get_cart_with_items(self, cart_dao, mock_connection_pool):
        """Test retrieving full cart with items - verifies complex JOIN query"""
        expected_items = [
            {
                'CART_ITEM_ID': 1,
                'SKU': '001ST001SN001A',
                'PRODUCT_NAME': 'Premium Watch',
                'QUANTITY': 2,
                'UNIT_PRICE_CENTS': 9999,
                'SERIES_NAME': 'Classic',
                'STYLE_NAME': 'Sport',
                'MODIFIER_NAME': 'Gold',
                'URL': 'http://example.com/watch.jpg'
            },
            {
                'CART_ITEM_ID': 2,
                'SKU': '002ST002SN002B',
                'PRODUCT_NAME': 'Designer Watch',
                'QUANTITY': 1,
                'UNIT_PRICE_CENTS': 15999,
                'SERIES_NAME': 'Modern',
                'STYLE_NAME': 'Casual',
                'MODIFIER_NAME': 'Silver',
                'URL': 'http://example.com/watch2.jpg'
            }
        ]
        
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.fetch_assoc.side_effect = expected_items + [None]
            
            result = cart_dao.get_cart(123)
            
            # Verify result
            assert result['status'] == 'success'
            assert len(result['output']) == 2
            assert result['output'][0]['SKU'] == '001ST001SN001A'
            assert result['output'][1]['SKU'] == '002ST002SN002B'
            
            # Verify SQL contains all necessary JOINs
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'INNER JOIN USER01.CART_ITEMS' in sql_call
            assert 'INNER JOIN USER01.INVENTORY' in sql_call
            assert 'INNER JOIN USER01.PRODUCT_VARIANTS' in sql_call
            assert 'WHERE C.USER_ID' in sql_call
            assert 'STATUS' in sql_call  # Should filter by cart status
            
            # Verify parameter binding
            mock_db.bind_param.assert_called_once_with(mock_stmt, 1, 123)
    
