class TestOrdersDAO:
    """Unit tests for OrdersDAO class"""

    @pytest.mark.unit
    def test_get_user_orders_multiple(self, orders_dao, mock_connection_pool):
        """Test retrieving all orders for a user with order history"""
        user_orders = [
            {'ID': 101, 'TOTAL_CENTS': 15997, 'USER_ID': 123, 'PLACED_AT': '2026-01-15'},
            {'ID': 102, 'TOTAL_CENTS': 29999, 'USER_ID': 123, 'PLACED_AT': '2026-02-20'},
            {'ID': 103, 'TOTAL_CENTS': 5999, 'USER_ID': 123, 'PLACED_AT': '2026-03-10'}
        ]
        
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.fetch_assoc.side_effect = user_orders + [None]
            
            result = orders_dao.get_user_orders(user_id=123)
            
            assert result['status'] == 'success'
            assert len(result['output']) == 3
            assert result['output'][0]['ID'] == 101
            assert result['output'][1]['TOTAL_CENTS'] == 29999
            
            # Verify SQL
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'SELECT' in sql_call
            assert 'FROM USER01.ORDERS' in sql_call
            assert 'USER_ID' in sql_call
            
            # Verify parameter binding
            mock_db.bind_param.assert_called_once_with(mock_stmt, 1, 123)
    
