import pytest
from unittest.mock import Mock, patch, MagicMock, call
import sys


# Mock ibm_db module before any DAO imports
sys.modules['ibm_db'] = MagicMock()


# Mock the config loading BEFORE importing DAO modules
@pytest.fixture(scope="module", autouse=True)
def mock_config_for_all_tests():
    """Mock configuration loading to prevent import-time failures"""
    mock_config = MagicMock()
    mock_config.__getitem__.return_value = {
        'clidriver_path': 'C:/mock/path',
        'username': 'testuser',
        'password': 'testpass',
        'database': 'testdb',
        'hostname': 'localhost',
        'port': '50000'
    }
    
    with patch('configparser.ConfigParser') as mock_parser:
        mock_parser_instance = MagicMock()
        mock_parser_instance.__getitem__ = mock_config.__getitem__
        mock_parser.return_value = mock_parser_instance
        
        with patch('os.add_dll_directory'):
            yield


@pytest.fixture
def mock_connection_pool():
    """Mock database connection pool - shared fixture"""
    pool = Mock()
    mock_conn = MagicMock()
    pool.get_connection = Mock(return_value=mock_conn)
    pool.return_connection = Mock()
    return pool


@pytest.fixture
def cart_dao(mock_connection_pool):
    """Initialize CartDAO with mock connection pool"""
    from Backend.DatabaseAccess.cart_dao import CartDAO
    return CartDAO(mock_connection_pool)


@pytest.fixture
def orders_dao(mock_connection_pool):
    """Initialize OrdersDAO with mock connection pool"""
    from Backend.DatabaseAccess.orders_dao import OrdersDAO
    return OrdersDAO(mock_connection_pool)


class TestCartDAO:
    """Unit tests for CartDAO class - Testing individual DAO methods"""
    
    @pytest.mark.unit
    def test_create_cart_success(self, cart_dao, mock_connection_pool):
        """Test creating a new cart for user - verifies SQL, binding, commit"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            
            result = cart_dao.create_cart(user_id=123)
            
            # Verify result
            assert result['status'] == 'success'
            
            # Verify SQL contains correct table and columns
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'USER01.CARTS' in sql_call
            assert 'USER_ID' in sql_call
            assert 'INSERT' in sql_call
            
            # Verify parameter binding
            mock_db.bind_param.assert_called_once_with(mock_stmt, 1, 123)
            
            # Verify execution and commit
            mock_db.execute.assert_called_once_with(mock_stmt)
            mock_db.commit.assert_called_once_with(mock_conn)
            
            # Verify connection returned to pool
            mock_connection_pool.return_connection.assert_called_once_with(mock_conn)

    @pytest.mark.unit
    def test_create_cart_error_with_rollback(self, cart_dao, mock_connection_pool):
        """Test error handling when creating cart - verifies rollback and connection cleanup"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_db.prepare.side_effect = Exception("Database connection lost")
            
            result = cart_dao.create_cart(user_id=123)
            
            # Verify error response
            assert result['status'] == 'error'
            assert 'reason' in result
            assert 'Database connection lost' in str(result['reason'])
            
            # Verify rollback was called on error
            mock_db.rollback.assert_called_once_with(mock_conn)
            
            # Verify connection still returned to pool (finally block)
            mock_connection_pool.return_connection.assert_called_once_with(mock_conn)
            
            # Verify commit was never called
            mock_db.commit.assert_not_called()
    
    @pytest.mark.unit
    @pytest.mark.parametrize("user_id,description", [
        (1, "minimum user ID"),
        (999999, "large user ID"),
        (0, "zero user ID - edge case"),
        (-1, "negative user ID - edge case"),
    ])
    def test_create_cart_various_user_ids(self, cart_dao, mock_connection_pool, user_id, description):
        """Test creating cart with various user ID edge cases"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            
            result = cart_dao.create_cart(user_id=user_id)
            
            assert result['status'] == 'success', f"Failed for {description}"
            mock_db.bind_param.assert_called_with(mock_stmt, 1, user_id)

    @pytest.mark.unit
    def test_get_cart_id_found(self, cart_dao, mock_connection_pool):
        """Test retrieving cart ID for user - single cart"""
        expected_cart = {'ID': 42}
        
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.cart_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.fetch_assoc.side_effect = [expected_cart, None]
            
            result = cart_dao.get_cart_id(123)
            
            # Verify result structure
            assert result['status'] == 'success'
            assert len(result['output']) == 1
            assert result['output'][0]['ID'] == 42
            
            # Verify SQL query
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'SELECT ID' in sql_call
            assert 'USER01.CARTS' in sql_call
            assert 'USER_ID' in sql_call
            
            # Verify parameter binding
            mock_db.bind_param.assert_called_once_with(mock_stmt, 1, 123)
            
            # Verify connection management
            mock_connection_pool.return_connection.assert_called_once_with(mock_conn)
    
