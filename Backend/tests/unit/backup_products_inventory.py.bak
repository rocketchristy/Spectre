    @pytest.mark.unit
    def test_get_order_id_most_recent(self, orders_dao, mock_connection_pool):
        """Test retrieving most recent order ID for user - verifies ORDER BY DESC"""
        expected_order = {'ID': 102}
        
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.fetch_assoc.side_effect = [expected_order, None]
            
            result = orders_dao.get_order_id(123)
            
            assert result['status'] == 'success'
            assert len(result['output']) == 1
            assert result['output'][0]['ID'] == 102
            
            # Verify SQL gets most recent order
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'ORDER BY CREATED_AT DESC' in sql_call
            assert 'FETCH FIRST 1 ROW ONLY' in sql_call
            
            # Verify parameter
            mock_db.bind_param.assert_called_once_with(mock_stmt, 1, 123)
    
    @pytest.mark.unit
    def test_get_order_id_no_orders(self, orders_dao, mock_connection_pool):
