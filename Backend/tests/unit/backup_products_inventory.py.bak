            result = orders_dao.get_order_id(999)
            
            assert result['status'] == 'success'
            assert result['output'] == []

    @pytest.mark.unit
    def test_update_order_cost_success(self, orders_dao, mock_connection_pool):
        """Test updating order cost - verifies both SUBTOTAL and TOTAL updated"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.num_rows.return_value = 1
            
            result = orders_dao.update_order_cost(cost=19997, order_id=101)
            
            assert result['status'] == 'success'
            
            # Verify SQL updates both subtotal and total
            sql_call = mock_db.prepare.call_args[0][1]
            assert 'UPDATE USER01.ORDERS' in sql_call
            assert 'SUBTOTAL_CENTS' in sql_call
            assert 'TOTAL_CENTS' in sql_call
            assert 'WHERE ID' in sql_call
            
            # Verify parameters (cost appears twice: subtotal and total)
            expected_calls = [
                call(mock_stmt, 1, 19997),  # subtotal
                call(mock_stmt, 2, 19997),  # total
                call(mock_stmt, 3, 101),    # order_id
            ]
            mock_db.bind_param.assert_has_calls(expected_calls)
            
            # Verify transaction
            mock_db.execute.assert_called_once()
            mock_db.commit.assert_called_once()

    @pytest.mark.unit
    def test_update_order_cost_not_found(self, orders_dao, mock_connection_pool):
        """Test error when order not found"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.num_rows.return_value = 0
            
            result = orders_dao.update_order_cost(19997, 9999)
            
            assert result['status'] == 'error'
            assert 'not found' in result['reason'].lower()
            
            # No commit when order not found
            mock_db.commit.assert_not_called()
    
    @pytest.mark.unit
    @pytest.mark.parametrize("cost", [0, 1, 100, 999999, -100])
    def test_update_order_cost_various_values(self, orders_dao, mock_connection_pool, cost):
        """Test updating order with various cost values including edge cases"""
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.num_rows.return_value = 1
            
            result = orders_dao.update_order_cost(cost, 101)
            
            assert result['status'] == 'success'
            # Verify cost parameter
            calls = mock_db.bind_param.call_args_list
            assert calls[0] == call(mock_stmt, 1, cost)
            assert calls[1] == call(mock_stmt, 2, cost)


# ============================================================================
# ORDER USE CASE TESTS - Testing checkout and order creation scenarios
# ============================================================================

@pytest.mark.unit
@pytest.mark.integration
class TestOrderUseCases:
    """Test real-world order and checkout scenarios"""
    
    def test_complete_checkout_flow(self, orders_dao, cart_dao, mock_connection_pool):
        """
        USE CASE: User completes checkout
        1. Create order from cart
        2. Add all cart items to order
        3. Update order total
        4. Clear cart (tested in CartDAO)
        """
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            mock_db.num_rows.return_value = 1
            
            # Step 1: Create order
            result1 = orders_dao.add_order(
                user_id=123,
                currency_code='USD',
                subtotal_cents=25998,  # 2 items
                billing_address_id=1,
                shipping_address_id=1
            )
            assert result1['status'] == 'success'
            
            # Step 2: Add order items (simulating cart -> order transfer)
            result2 = orders_dao.add_order_item(101, 5, 1, 'SKU1', 'Watch', 9999, 'USD', 1)
            assert result2['status'] == 'success'
            
            result3 = orders_dao.add_order_item(101, 6, 1, 'SKU2', 'Band', 15999, 'USD', 1)
            assert result3['status'] == 'success'
            
            # Step 3: Update total (if tax/shipping added)
            result4 = orders_dao.update_order_cost(28998, 101)
            assert result4['status'] == 'success'
    
    def test_order_history_retrieval(self, orders_dao, mock_connection_pool):
        """
        USE CASE: User views past orders
        """
        mock_conn = mock_connection_pool.get_connection.return_value
        with patch('Backend.DatabaseAccess.orders_dao.ibm_db') as mock_db:
            mock_stmt = Mock()
            mock_db.prepare.return_value = mock_stmt
            
            # User has 3 past orders
            orders = [
                {'ID': 1, 'TOTAL_CENTS': 10000, 'PLACED_AT': '2026-01-01'},
                {'ID': 2, 'TOTAL_CENTS': 20000, 'PLACED_AT': '2026-02-01'},
                {'ID': 3, 'TOTAL_CENTS': 30000, 'PLACED_AT': '2026-03-01'},
            ]
            mock_db.fetch_assoc.side_effect = orders + [None]
            
            result = orders_dao.get_user_orders(123)
            
            assert result['status'] == 'success'
            assert len(result['output']) == 3
            # Verify chronological order
            assert result['output'][0]['ID'] == 1
            assert result['output'][2]['ID'] == 3

